# Environment
APP_ENV=development
DEBUG=true

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=ai_video
POSTGRES_PASSWORD=changeme
POSTGRES_DB=ai_video_studio

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB=ai_video_studio

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ai-video-studio
MINIO_SECURE=false

# JWT
JWT_SECRET_KEY=dev-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# LLM - Qwen (via DashScope OpenAI-compatible API)
# URL is hardcoded in llm_gateway.py: https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=your-dashscope-api-key
QWEN_MODEL=qwen-plus

# Image Gen - GPT Image 1 (OpenAI)
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_IMAGE_MODEL=gpt-image-1

# Video Gen - Kling 3.0
KLING_API_KEY=your-kling-api-key
KLING_ACCESS_KEY=your-kling-access-key
KLING_SECRET_KEY=your-kling-secret-key
KLING_BASE_URL=https://api.klingai.com

# TTS - Qwen TTS (via DashScope OpenAI-compatible API)
QWEN_TTS_API_KEY=your-dashscope-api-key
QWEN_TTS_MODEL=qwen-tts
QWEN_TTS_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_TTS_VOICE=alloy
QWEN_TTS_RESPONSE_FORMAT=mp3

# Music - MiniMax
MINIMAX_API_KEY=your-minimax-api-key
