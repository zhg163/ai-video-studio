# Environment
APP_ENV=development
DEBUG=true

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=ai_video
POSTGRES_PASSWORD=changeme
POSTGRES_DB=ai_video_studio

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB=ai_video_studio

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ai-video-studio
MINIO_SECURE=false

# JWT
JWT_SECRET_KEY=dev-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# LLM - Qwen
QWEN_API_KEY=your-qwen-api-key
QWEN_MODEL=qwen-plus

# Image Gen - GPT Image 1
OPENAI_API_KEY=your-openai-api-key

# Video Gen - Kling
KLING_API_KEY=your-kling-api-key
KLING_ACCESS_KEY=your-kling-access-key
KLING_SECRET_KEY=your-kling-secret-key

# TTS - Qwen TTS
QWEN_TTS_API_KEY=your-qwen-tts-api-key

# Music - MiniMax
MINIMAX_API_KEY=your-minimax-api-key
